<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================ -->
    <!--  PALETA DE COLORES                                           -->
    <!-- ============================================================ -->
    <Color x:Key="BackgroundDark">#FF1A1A2E</Color>
    <Color x:Key="BackgroundMedium">#FF16213E</Color>
    <Color x:Key="BackgroundLight">#FF0F3460</Color>
    <Color x:Key="AccentPrimary">#FFE94560</Color>
    <Color x:Key="AccentSecondary">#FF533483</Color>
    <Color x:Key="TextPrimary">#FFF0F0F0</Color>
    <Color x:Key="TextSecondary">#FFB0B0C8</Color>
    <Color x:Key="TextMuted">#FF707088</Color>
    <Color x:Key="Success">#FF2ED573</Color>
    <Color x:Key="Warning">#FFFFA502</Color>
    <Color x:Key="Danger">#FFFF4757</Color>
    <Color x:Key="BorderColor">#FF2A2A4A</Color>
    <Color x:Key="CardBackground">#FF1E1E3F</Color>
    <Color x:Key="InputBackground">#FF252550</Color>
    <Color x:Key="HoverColor">#FF2E2E55</Color>

    <SolidColorBrush x:Key="BrushBackground"    Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="BrushCard"          Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="BrushAccent"        Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="BrushAccentSecond"  Color="{StaticResource AccentSecondary}"/>
    <SolidColorBrush x:Key="BrushText"          Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecond"    Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"     Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrushSuccess"       Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="BrushWarning"       Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="BrushDanger"        Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BrushBorder"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BrushInput"         Color="{StaticResource InputBackground}"/>
    <SolidColorBrush x:Key="BrushHover"         Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="BrushMedium"        Color="{StaticResource BackgroundMedium}"/>
    <SolidColorBrush x:Key="BrushLight"         Color="{StaticResource BackgroundLight}"/>

    <!-- ============================================================ -->
    <!--  FUENTES                                                     -->
    <!-- ============================================================ -->
    <FontFamily x:Key="FontPrimary">Segoe UI</FontFamily>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeNormal">13</sys:Double>
    <sys:Double x:Key="FontSizeMedium">15</sys:Double>
    <sys:Double x:Key="FontSizeLarge">18</sys:Double>
    <sys:Double x:Key="FontSizeTitle">24</sys:Double>
    <sys:Double x:Key="FontSizeHero">32</sys:Double>

    <!-- ============================================================ -->
    <!--  WINDOW BASE                                                 -->
    <!-- ============================================================ -->
    <Style x:Key="DarkWindow" TargetType="Window">
        <Setter Property="Background"   Value="{StaticResource BrushBackground}"/>
        <Setter Property="Foreground"   Value="{StaticResource BrushText}"/>
        <Setter Property="FontFamily"   Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSizeNormal}"/>
    </Style>

    <!-- ============================================================ -->
    <!--  TEXTBLOCKS                                                  -->
    <!-- ============================================================ -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecond}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMedium}"/>
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSmall}"/>
    </Style>

    <Style x:Key="AmountText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLarge}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
