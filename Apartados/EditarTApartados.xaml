<Window x:Class="POS.Apartados.EditarTApartado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Apartado" Height="auto" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label Content="Editar Apartado" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Label Content="Anticipo:"/>
            <TextBlock Text="{Binding Apartado.nAnticipo, StringFormat='C2'}" IsEnabled="{Binding IsEditEnabled}"/>

            <Label Content="Saldo Pendiente:"/>
            <TextBlock Text="{Binding Apartado.nSaldoPendiente, StringFormat='C2'}" IsEnabled="{Binding IsEditEnabled}"/>

            <Label Content="Cantidad a Abonar:"/>
            <TextBox x:Name="Txt_Abono" />

        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="0,10,0,0">
            <Button Content="Guardar" Width="100" Margin="5" Background="Green" Foreground="White" Click="Btn_Guardaar_Click"/>
            <Button Content="Cancelar" Width="100" Margin="5" Background="Red" Foreground="White" Click="Btn_Cancelaar_Click"/>
           
        </StackPanel>
    </Grid>
</Window>

