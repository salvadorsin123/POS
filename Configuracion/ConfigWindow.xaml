<Window x:Class="POS.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Inicial POS" Height="500" Width="700" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Bienvenido al Sistema POS" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#333"/>
            <TextBlock Text="Antes de empezar, define el rol de este equipo:" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,30" Foreground="#666"/>

            <StackPanel x:Name="PanelSeleccion" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnModoServidor" Click="btnModoServidor_Click" Width="200" Height="120" Margin="15" Background="White" BorderBrush="#007ACC" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="SERVIDOR" FontWeight="Bold" FontSize="18" Foreground="#007ACC" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Caja Principal)" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="Aquí se guardarán los datos" FontSize="10" FontStyle="Italic" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnModoCliente" Click="btnModoCliente_Click" Width="200" Height="120" Margin="15" Background="White" BorderBrush="#28A745" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="CLIENTE" FontWeight="Bold" FontSize="18" Foreground="#28A745" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Caja Secundaria)" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="Se conecta a la Principal" FontSize="10" FontStyle="Italic" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border x:Name="PanelServidor" Visibility="Collapsed" BorderBrush="#007ACC" BorderThickness="1" CornerRadius="5" Background="#F0F8FF" Padding="20" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Configurando Servidor..." FontSize="18" FontWeight="Bold" Foreground="#007ACC"/>
                    <TextBlock Text="Hemos abierto el puerto 1433 y detectado tu IP." Margin="0,10,0,0"/>

                    <TextBlock Text="IP PARA LAS OTRAS CAJAS:" Margin="0,20,0,5" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox x:Name="txtIPResult" FontSize="32" FontWeight="Bold" TextAlignment="Center" IsReadOnly="True" BorderThickness="0" Background="Transparent" Foreground="#333" Text="192.168.1.XX"/>

                    <Button Content="Guardar Configuración y Empezar" Click="btnGuardarServidor_Click" Height="40" Margin="0,20,0,0" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    <Button Content="Cancelar / Volver" Click="btnVolver_Click" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="#555"/>
                </StackPanel>
            </Border>

            <Border x:Name="PanelCliente" Visibility="Collapsed" BorderBrush="#28A745" BorderThickness="1" CornerRadius="5" Background="#F0FFF4" Padding="20" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Conectar a Caja Principal" FontSize="18" FontWeight="Bold" Foreground="#28A745"/>
                    <TextBlock Text="Ingresa la IP que aparece en la pantalla del Servidor:" Margin="0,10,0,5"/>

                    <TextBox x:Name="txtIpServidorInput" FontSize="20" Padding="5" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Probar Conexión" Click="btnProbar_Click" Width="120" Height="30" Margin="0,0,10,0"/>
                        <Button x:Name="btnFinalizarCliente" Content="Guardar y Conectar" Click="btnGuardarCliente_Click" Width="140" Height="30" IsEnabled="False" Background="#28A745" Foreground="White"/>
                    </StackPanel>

                    <Button Content="Cancelar / Volver" Click="btnVolver_Click" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="#555"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>