<Window x:Class="POS.Empleados.EditarTEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Editar Empleado" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Formulario para editar los datos del empleado -->
        <StackPanel>
            <Label x:Name="Lbl_Empleado" Content="Empleado" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Label Content="ID Empleado:" Visibility="Collapsed"/>
            <TextBox x:Name="Ttx_id_Empleado" Text="{Binding nEmpleadoID}" Visibility="Collapsed"/>
            

            <Label Content="Nombre:"/>
            <TextBox Text="{Binding cNombreUsuario}"/>

            <Label Content="Contraseña:"/>
            <TextBox Text="{Binding cContrasena}" IsReadOnly="True"/>
            
            <Label Content="Nueva Contrasña:"/>
            <TextBox x:Name="Txt_NuevaContrasena" IsReadOnly="False"/>


            <Label Content="Salario:"/>
            <TextBox Text="{Binding nSalario}"/>
            
            <Label Content="Tipo de empleado:"/>
            <ComboBox x:Name="Cbo_TipoEmpleado" 
            SelectedItem="{Binding cTipo}"/>

            <Label Content="Ventas:"/>
            <TextBox Text="{Binding nVentas}"/>
        </StackPanel>

        <!-- Botones para guardar o cancelar -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="0,0,0,0">
            <Button Content="Guardar" Width="95" Height="35" Background="#FFB800" Foreground="Black" Margin="10" Click="Btn_Guardar_Click"/>
            <Button Content="Cancelar" Width="95" Height="35" Background="Red" Foreground="White" Margin="5" Click="Btn_Cancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>

