<Window x:Class="POS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:POS.ViewModels"
        xmlns:h="clr-namespace:POS.Helpers"
        Title="POS — Inicio de Sesión"
        Height="520" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindow}">

    <Window.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Fondo con gradiente -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF1A1A2E" Offset="0"/>
                <GradientStop Color="#FF16213E" Offset="0.5"/>
                <GradientStop Color="#FF0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Círculos decorativos -->
        <Ellipse Width="300" Height="300" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-80,-80,0" Opacity="0.06">
            <Ellipse.Fill>
                <SolidColorBrush Color="#FFE94560"/>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="200" Height="200" HorizontalAlignment="Left"
                 VerticalAlignment="Bottom" Margin="-60,0,0,-60" Opacity="0.05">
            <Ellipse.Fill>
                <SolidColorBrush Color="#FF533483"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Contenido principal -->
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <!-- Logo / Título -->
            <Border Background="#22E94560" CornerRadius="50" Width="80" Height="80"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets"
                           FontSize="36" HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrushAccent}"/>
            </Border>

            <TextBlock Text="SISTEMA POS" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="Inicia sesión para continuar" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,4,0,30"
                       Foreground="{StaticResource BrushTextMuted}"/>

            <!-- Usuario -->
            <TextBlock Text="USUARIO" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <TextBox x:Name="TxtUsername"
                         Style="{StaticResource DarkTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="Input_KeyDown"/>
                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,12,0" IsHitTestVisible="False"
                           Foreground="{StaticResource BrushTextMuted}" FontSize="14"/>
            </Grid>

            <!-- Contraseña -->
            <TextBlock Text="CONTRASEÑA" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource DarkPasswordBox}"
                             KeyDown="Input_KeyDown"/>
                <TextBlock Text="&#xE727;" FontFamily="Segoe MDL2 Assets"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,12,0" IsHitTestVisible="False"
                           Foreground="{StaticResource BrushTextMuted}" FontSize="14"/>
            </Grid>

            <!-- Error -->
            <Border Background="#22FF4757" CornerRadius="6" Padding="12,8"
                    Margin="0,10,0,0"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE730;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource BrushDanger}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource BrushDanger}" FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Botón Login -->
            <Button Content="INICIAR SESIÓN"
                    Style="{StaticResource BtnPrimary}"
                    Margin="0,16,0,0" Height="44"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource BoolToVis},
                                ConverterParameter=invert}"
                    Click="BtnLogin_Click"/>

            <!-- Loading -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Verificando..." FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
