<Window x:Class="POS.Views.Dialogs.EditEmpleadoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Empleado" Height="500" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DarkWindow}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitulo" Text="Nuevo Empleado"
                   Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="NOMBRE *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtNombre" Style="{StaticResource DarkTextBox}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="APELLIDO PATERNO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtAP" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="APELLIDO MATERNO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtAM" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="USUARIO *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtUsername" Style="{StaticResource DarkTextBox}"/>

                <TextBlock x:Name="LblPass" Text="CONTRASEÑA *" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource DarkPasswordBox}"/>
                <TextBlock Text="(dejar en blanco para no cambiar)" FontSize="10"
                           Foreground="{StaticResource BrushTextMuted}" x:Name="TxtPassHint"
                           Visibility="Collapsed" Margin="0,2,0,0"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ROL *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CbxTipo" Style="{StaticResource DarkComboBox}"
                                  DisplayMemberPath="Nombre"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SALARIO" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtSalario" Style="{StaticResource DarkTextBox}" Text="0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="TELÉFONO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtTelefono" Style="{StaticResource DarkTextBox}"/>

                <TextBlock Text="CORREO" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtCorreo" Style="{StaticResource DarkTextBox}"/>

                <TextBlock x:Name="TxtError" Foreground="{StaticResource BrushDanger}"
                           FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar" Style="{StaticResource BtnOutline}"
                    Padding="16,9" Margin="0,0,8,0" Click="BtnCancelar_Click"/>
            <Button Content="Guardar" Style="{StaticResource BtnPrimary}"
                    Padding="16,9" Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
