<Window x:Class="POS.Views.Dialogs.EditProductoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Producto" Height="460" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DarkWindow}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitulo" Text="Nuevo Producto"
                   Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="NOMBRE / MODELO *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtModelo" Style="{StaticResource DarkTextBox}"/>

                <TextBlock Text="CÓDIGO DE BARRAS" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtCodigo" Style="{StaticResource DarkTextBox}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRECIO *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtPrecio" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DESCUENTO %" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDescuento" Style="{StaticResource DarkTextBox}" Text="0"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="STOCK *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtCantidad" Style="{StaticResource DarkTextBox}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CATEGORÍA" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CbxCategoria" Style="{StaticResource DarkComboBox}"
                                  DisplayMemberPath="Nombre"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="DESCRIPCIÓN" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDescripcion" Style="{StaticResource DarkTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock x:Name="TxtError" Foreground="{StaticResource BrushDanger}"
                           FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar" Style="{StaticResource BtnOutline}"
                    Padding="16,9" Margin="0,0,8,0"
                    Click="BtnCancelar_Click"/>
            <Button Content="Guardar" Style="{StaticResource BtnPrimary}"
                    Padding="16,9"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
