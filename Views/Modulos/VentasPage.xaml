<Page x:Class="POS.Views.Modulos.VentasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:POS.ViewModels"
      xmlns:h="clr-namespace:POS.Helpers"
      Background="Transparent" Title="Ventas">

    <Page.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <h:DecimalToCurrencyConverter x:Key="ToCurrency"/>
        <h:ZeroToVisibilityConverter x:Key="ZeroToVis"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ===== PANEL IZQUIERDO: Búsqueda + Carrito ===== -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Escaneo por código de barras -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="&#xE76D; Escanear / Buscar Producto"
                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{StaticResource BrushTextSecond}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCodigo" Grid.Column="0"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding CodigoBarras, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="TxtCodigo_KeyDown" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                                Content="&#xE76D;" FontFamily="Segoe MDL2 Assets"
                                Width="44" Padding="0"
                                Command="{Binding EscanearCommand}"/>
                    </Grid>

                    <!-- Búsqueda manual -->
                    <TextBox Margin="0,8,0,0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding BusquedaProducto, UpdateSourceTrigger=PropertyChanged}"/>

                    <ListBox x:Name="LstProductos"
                             ItemsSource="{Binding ProductosDisponibles}"
                             SelectedItem="{Binding ProductoSeleccionado}"
                             Background="Transparent" BorderThickness="0"
                             MaxHeight="130" Margin="0,4,0,0"
                             Visibility="{Binding ProductosDisponibles.Count, Converter={StaticResource ZeroToVis}, ConverterParameter=invert}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Modelo}"
                                               Foreground="{StaticResource BrushText}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Cantidad}"
                                               Foreground="{StaticResource BrushTextMuted}"
                                               Margin="8,0" VerticalAlignment="Center" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="{Binding PrecioFinal, Converter={StaticResource ToCurrency}}"
                                               Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                                <Setter Property="Padding"    Value="8,6"/>
                                <Setter Property="Cursor"     Value="Hand"/>
                                <EventSetter Event="MouseDoubleClick" Handler="ProductoItem_DoubleClick"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button Content="+ Agregar seleccionado" Style="{StaticResource BtnOutline}"
                            Margin="0,6,0,0" HorizontalAlignment="Left"
                            Visibility="{Binding ProductoSeleccionado, Converter={StaticResource BoolToVis}}"
                            Command="{Binding AgregarProductoCommand}"/>
                </StackPanel>
            </Border>

            <!-- Carrito -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding TotalItems, StringFormat='Carrito ({0} items)'}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"/>
                    <Button Grid.Column="1" Content="&#xE74D; Limpiar"
                            FontFamily="Segoe MDL2 Assets" Style="{StaticResource BtnOutline}"
                            Padding="10,6" FontSize="12"
                            Command="{Binding LimpiarCarritoCommand}"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                <!-- Tabla del carrito -->
                <DataGrid ItemsSource="{Binding Carrito}"
                          Style="{StaticResource DarkDataGrid}"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}"
                                            Width="*"/>
                        <DataGridTemplateColumn Header="Cant." Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"
                                             Padding="4,2" Width="50" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="P. Unit."
                                            Binding="{Binding PrecioUnitario, StringFormat=C2}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Subtotal"
                                            Binding="{Binding Subtotal, StringFormat=C2}"
                                            Width="90"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                            Style="{StaticResource BtnIcon}"
                                            Foreground="{StaticResource BrushDanger}"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.QuitarItemCommand,
                                                      RelativeSource={RelativeSource AncestorType=Page}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ===== PANEL DERECHO: Resumen y Cobro ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cliente -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="CLIENTE (OPCIONAL)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding ClientesDisponibles}"
                              SelectedItem="{Binding ClienteSeleccionado}"
                              DisplayMemberPath="NombreCompleto"/>
                </StackPanel>
            </Border>

            <!-- Totales -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="RESUMEN" Style="{StaticResource FieldLabel}"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Subtotal:" Foreground="{StaticResource BrushTextSecond}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Subtotal, Converter={StaticResource ToCurrency}}"
                                   Foreground="{StaticResource BrushText}"/>
                    </Grid>

                    <Grid Margin="0,4"
                          Visibility="{Binding Descuento, Converter={StaticResource ZeroToVis}, ConverterParameter=invert}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Descuentos:" Foreground="{StaticResource BrushTextSecond}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Descuento, Converter={StaticResource ToCurrency}}"
                                   Foreground="{StaticResource BrushDanger}"/>
                    </Grid>

                    <CheckBox Content="Aplicar IVA 16%" Style="{StaticResource DarkCheckBox}"
                              IsChecked="{Binding AplicarIva}" Margin="0,6,0,0"/>

                    <Grid Margin="0,4"
                          Visibility="{Binding IVA, Converter={StaticResource ZeroToVis}, ConverterParameter=invert}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IVA (16%):" Foreground="{StaticResource BrushTextSecond}"/>
                        <TextBlock Grid.Column="1" Text="{Binding IVA, Converter={StaticResource ToCurrency}}"
                                   Foreground="{StaticResource BrushText}"/>
                    </Grid>

                    <Separator Style="{StaticResource DarkSeparator}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TOTAL:" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BrushText}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Total, Converter={StaticResource ToCurrency}}"
                                   Style="{StaticResource AmountText}"/>
                    </Grid>

                    <!-- Efectivo -->
                    <TextBlock Text="EFECTIVO RECIBIDO" Style="{StaticResource FieldLabel}" Margin="0,16,0,3"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding EfectivoRecibido, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

                    <Grid Margin="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CAMBIO:" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextSecond}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Cambio, Converter={StaticResource ToCurrency}}"
                                   FontWeight="Bold" FontSize="15"
                                   Foreground="{StaticResource BrushSuccess}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Botón cobrar -->
            <Button Grid.Row="2" Content="&#xE8A1;  COBRAR VENTA"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource BtnSuccess}"
                    Height="54" FontSize="15"
                    VerticalAlignment="Top"
                    Command="{Binding ConfirmarVentaCommand}"/>
        </Grid>
    </Grid>
</Page>
