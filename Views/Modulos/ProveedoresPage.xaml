<Page x:Class="POS.Views.Modulos.ProveedoresPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Proveedores">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnPrimary}"
                        Content="&#xE109; Nuevo" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding NuevoCommand}"/>
                <Button Style="{StaticResource BtnSecondary}"
                        Content="&#xE70F; Editar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding EditarCommand}"/>
                <Button Style="{StaticResource BtnDanger}"
                        Content="&#xE74D; Eliminar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8"
                        Command="{Binding EliminarCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
            <DataGrid ItemsSource="{Binding Proveedores}"
                      SelectedItem="{Binding SelectedProveedor}"
                      Style="{StaticResource DarkDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"         Binding="{Binding IdProveedor}" Width="55"/>
                    <DataGridTextColumn Header="Nombre"     Binding="{Binding Nombre}"      Width="*"/>
                    <DataGridTextColumn Header="Contacto"   Binding="{Binding Contacto}"    Width="140"/>
                    <DataGridTextColumn Header="Teléfono"   Binding="{Binding Telefono}"    Width="120"/>
                    <DataGridTextColumn Header="Correo"     Binding="{Binding Correo}"      Width="180"/>
                    <DataGridTextColumn Header="RFC"        Binding="{Binding RFC}"         Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
