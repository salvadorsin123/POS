<Page x:Class="POS.Views.Modulos.EmpleadosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:POS.Helpers"
      Background="Transparent" Title="Empleados">

    <Page.Resources>
        <h:BoolToColorConverter x:Key="BoolToColor"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnPrimary}"
                        Content="&#xE109; Nuevo" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding NuevoCommand}"/>
                <Button Style="{StaticResource BtnSecondary}"
                        Content="&#xE70F; Editar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding EditarCommand}"/>
                <Button Style="{StaticResource BtnOutline}"
                        Content="&#xE8E5; Activar/Desactivar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8"
                        Command="{Binding ToggleActivoCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
            <DataGrid ItemsSource="{Binding Empleados}"
                      SelectedItem="{Binding SelectedEmpleado}"
                      Style="{StaticResource DarkDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"       Binding="{Binding IdEmpleado}"     Width="55"/>
                    <DataGridTextColumn Header="Nombre"   Binding="{Binding NombreCompleto}" Width="*"/>
                    <DataGridTextColumn Header="Usuario"  Binding="{Binding Username}"       Width="110"/>
                    <DataGridTextColumn Header="Rol"      Binding="{Binding NombreTipo}"     Width="120"/>
                    <DataGridTextColumn Header="Ventas"   Binding="{Binding NumVentas}"      Width="70"/>
                    <DataGridTextColumn Header="Salario"  Binding="{Binding Salario, StringFormat=C2}" Width="100"/>
                    <DataGridTemplateColumn Header="Estado" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="EstadoBorder" CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF2ED573"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                                    <Setter Property="Background" Value="#FFFF4757"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Activo"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activo}" Value="False">
                                                        <Setter Property="Text" Value="Inactivo"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
