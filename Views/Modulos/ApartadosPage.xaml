<Page x:Class="POS.Views.Modulos.ApartadosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:POS.Helpers"
      Background="Transparent" Title="Apartados">

    <Page.Resources>
        <h:DecimalToCurrencyConverter x:Key="ToCurrency"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource BtnPrimary}"
                            Content="&#xE109; Nuevo Apartado" FontFamily="Segoe MDL2 Assets"
                            Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding NuevoCommand}"/>
                    <Button Style="{StaticResource BtnOutline}"
                            Content="&#xE72C; Actualizar" FontFamily="Segoe MDL2 Assets"
                            Padding="14,8"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
                <DataGrid ItemsSource="{Binding Apartados}"
                          SelectedItem="{Binding SelectedApartado}"
                          Style="{StaticResource DarkDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"        Binding="{Binding IdApartado}"  Width="50"/>
                        <DataGridTextColumn Header="Cliente"  Binding="{Binding NombreCliente}" Width="*"/>
                        <DataGridTextColumn Header="Total"    Binding="{Binding Total, StringFormat=C2}" Width="90"/>
                        <DataGridTextColumn Header="Anticipo" Binding="{Binding Anticipo, StringFormat=C2}" Width="90"/>
                        <DataGridTextColumn Header="Pendiente" Binding="{Binding SaldoPendiente, StringFormat=C2}" Width="90"/>
                        <DataGridTextColumn Header="Estado"   Binding="{Binding Estado}" Width="90"/>
                        <DataGridTextColumn Header="Límite"   Binding="{Binding FechaLimite, StringFormat=dd/MM/yy}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Panel de pago -->
        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="APLICAR PAGO" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding SelectedApartado.NombreCliente}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}" Margin="0,4,0,8"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Saldo pendiente:" Foreground="{StaticResource BrushTextSecond}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SelectedApartado.SaldoPendiente, Converter={StaticResource ToCurrency}}"
                                   Foreground="{StaticResource BrushAccent}" FontWeight="Bold"/>
                    </Grid>

                    <TextBlock Text="MONTO A PAGAR" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding MontoPago, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

                    <Button Content="&#xE8A1; Aplicar Pago" Style="{StaticResource BtnSuccess}"
                            FontFamily="Segoe MDL2 Assets"
                            Margin="0,12,0,0" Height="40"
                            Command="{Binding AplicarPagoCommand}"/>

                    <Button Content="&#xE711; Cancelar Apartado" Style="{StaticResource BtnDanger}"
                            FontFamily="Segoe MDL2 Assets"
                            Margin="0,8,0,0" Height="40"
                            Command="{Binding CancelarApartadoCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
