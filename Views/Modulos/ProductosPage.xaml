<Page x:Class="POS.Views.Modulos.ProductosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:POS.Helpers"
      Background="Transparent" Title="Productos">

    <Page.Resources>
        <h:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <h:StockColorConverter x:Key="StockColor"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,12,0"/>
                <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                        Content="&#xE109; Nuevo" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding NuevoCommand}"/>
                <Button Grid.Column="2" Style="{StaticResource BtnSecondary}"
                        Content="&#xE70F; Editar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding EditarCommand}"/>
                <Button Grid.Column="3" Style="{StaticResource BtnDanger}"
                        Content="&#xE74D; Eliminar" FontFamily="Segoe MDL2 Assets"
                        Padding="14,8"
                        Command="{Binding EliminarCommand}"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="0">
            <DataGrid ItemsSource="{Binding Productos}"
                      SelectedItem="{Binding SelectedProducto}"
                      Style="{StaticResource DarkDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"     Binding="{Binding IdProducto}" Width="55"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="110"/>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Modelo}" Width="*"/>
                    <DataGridTextColumn Header="Categoría" Binding="{Binding NombreCategoria}" Width="130"/>
                    <DataGridTextColumn Header="Precio"  Binding="{Binding Precio, StringFormat=C2}" Width="90"/>
                    <DataGridTextColumn Header="Desc. %" Binding="{Binding Descuento, StringFormat=N1}" Width="70"/>
                    <DataGridTemplateColumn Header="Stock" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                        Background="{Binding Cantidad, Converter={StaticResource StockColor}}">
                                    <TextBlock Text="{Binding Cantidad}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
