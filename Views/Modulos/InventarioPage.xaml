<Page x:Class="POS.Views.Modulos.InventarioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" Title="Categorías">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de categorías -->
        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0" Padding="0">
            <DataGrid ItemsSource="{Binding Categorias}"
                      SelectedItem="{Binding SelectedCategoria}"
                      Style="{StaticResource DarkDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding IdCategoria}"  Width="55"/>
                    <DataGridTextColumn Header="Nombre"      Binding="{Binding Nombre}"       Width="*"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}"  Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Formulario -->
        <Border Grid.Column="1" Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}" Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Nueva Categoría"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModoEdicion}" Value="True">
                                    <Setter Property="Text" Value="Editar Categoría"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="NOMBRE *" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="DESCRIPCIÓN" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Separator Style="{StaticResource DarkSeparator}"/>

                <Button Content="&#xE74E; Guardar Categoría"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource BtnPrimary}"
                        Height="40" Margin="0,0,0,8"
                        Command="{Binding GuardarCommand}"/>

                <Button Content="&#xE109; Nueva Categoría"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource BtnOutline}"
                        Height="40" Margin="0,0,0,8"
                        Command="{Binding NuevoCommand}"/>

                <Button Content="&#xE74D; Eliminar"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource BtnDanger}"
                        Height="40"
                        Command="{Binding EliminarCommand}"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource BrushDanger}"
                           FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
