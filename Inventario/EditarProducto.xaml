<Window x:Class="POS.Inventario.EditarProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Categorias" Height="200" Width="auto"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <StackPanel VerticalAlignment="Top" Margin="0,20,0,0" >
            <!-- Enlaces para los campos del producto -->
            <Label Content="Nombre Categoria:"/>
            <TextBox x:Name="Txt_Nombre" Width="300" Margin="0,5" Text="{Binding Categoria, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="Btn_Guardar" Content="Guardar" Width="100" Margin="5" Background="Green" Foreground="White" Click="Btn_Guardar_Click"/>
                <Button x:Name="Btn_Cancelar" Content="Cancelar" Width="100" Margin="5" Background="Red" Foreground="White" Click="Btn_Cancelar_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

