<UserControl x:Class="POS.Productos.Productos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#FAFAFA"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filtro de búsqueda -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="Buscar producto:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#333"/>
            <TextBox x:Name="Txt_BuscarProducto"
                     Width="250"
                     Height="28"
                     Margin="10,0,0,0"
                     Padding="5"
                     FontSize="13"
                     Background="White"
                     BorderBrush="#BEBEBE"
                     BorderThickness="1"
                     TextChanged="Txt_BuscarProducto_TextChanged"/>
        </StackPanel>

        <!-- Tabla de productos -->
        <DataGrid x:Name="DataGrid_Productos"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  Height="400"
                  Margin="0,0,0,15"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F0F0F0"
                  GridLinesVisibility="Vertical"
                  BorderBrush="#DDD"
                  BorderThickness="1"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding nProductoID}" Width="60"/>
                <DataGridTextColumn Header="Modelo" Binding="{Binding cModelo}" Width="*"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding nPrecio}" Width="100"/>
                <DataGridTextColumn Header="Descuento" Binding="{Binding nDescuento}" Width="100"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding nCantidad}" Width="100"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding cTipo}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="Btn_AgregarProducto"
                    Content="Agregar"
                    Width="100"
                    Height="32"
                    Margin="5"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Click="Btn_AgregarProducto_Click"/>
            <Button x:Name="Btn_EditarProducto"
                    Content="Editar"
                    Width="100"
                    Height="32"
                    Margin="5"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Background="#FFC107"
                    Foreground="Black"
                    BorderBrush="Transparent"
                    Click="Btn_EditarProducto_Click"/>
            <Button x:Name="Btn_EliminarProducto"
                    Content="Eliminar"
                    Width="100"
                    Height="32"
                    Margin="5"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Background="#F44336"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Click="Btn_EliminarProducto_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

