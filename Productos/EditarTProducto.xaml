<Window x:Class="POS.Productos.EditarTProducto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Editar Producto" Height="450" Width="800"
        Loaded="CargarCategoria">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label Content="Editar Producto" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Label Content="ID Producto:"/>
            <TextBox Text="{Binding nProductoID}" IsReadOnly="True"/>

            <Label Content="Modelo:"/>
            <TextBox Text="{Binding cModelo}"/>

            <Label Content="Precio:"/>
            <TextBox Text="{Binding nPrecio}"/>

            <Label Content="Descuento:"/>
            <TextBox Text="{Binding nDescuento}"/>

            <Label Content="Cantidad:"/>
            <TextBox Text="{Binding nCantidad}"/>

            <Label Content="Categoria:"/>
            <ComboBox x:Name="Cbo_Categoria" 
            SelectedItem="{Binding cTipo}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="0,10,0,0">
            <Button Content="Guardar" Width="90" Height="25" Background="#4CAF50" Foreground="White" Margin="5" Click="Btn_Guardarr_Click"/>
            <Button Content="Cancelar" Width="90" Margin="5" Background="Red" Foreground="White" Click="Btn_Cancelarr_Click"/>
        </StackPanel>
    </Grid>
</Window>