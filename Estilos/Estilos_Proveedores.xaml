<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colores globales -->
    <Color x:Key="ColorPrimario">#FF007ACC</Color>
    <Color x:Key="ColorSecundario">#FF2D2D30</Color>
    <Color x:Key="ColorTextoClaro">White</Color>
    <Color x:Key="ColorTextoOscuro">Black</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrushPrimario" Color="{StaticResource ColorPrimario}"/>
    <SolidColorBrush x:Key="BrushSecundario" Color="{StaticResource ColorSecundario}"/>
    <SolidColorBrush x:Key="BrushTextoClaro" Color="{StaticResource ColorTextoClaro}"/>
    <SolidColorBrush x:Key="BrushTextoOscuro" Color="{StaticResource ColorTextoOscuro}"/>

    <!-- Estilo para botones -->
    <Style TargetType="Button" x:Key="BotonBase">
        <Setter Property="Background" Value="{StaticResource BrushPrimario}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="5" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Estilo para TextBox -->
    <Style TargetType="TextBox" x:Key="EntradaTexto">
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="BorderBrush" Value="#ccc"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Estilo para Labels -->
    <Style TargetType="Label" x:Key="EtiquetaBase">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,5,0,2"/>
    </Style>

</ResourceDictionary>
