<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colores principales -->
    <Color x:Key="ColorPrimario">#FF007ACC</Color>
    <Color x:Key="ColorSecundario">#FF005A9E</Color>
    <Color x:Key="ColorFondo">#FFF9F9F9</Color>
    <Color x:Key="ColorTexto">#FF2C2C2C</Color>

    <!-- Brochas -->
    <SolidColorBrush x:Key="BrushPrimaria" Color="{StaticResource ColorPrimario}" />
    <SolidColorBrush x:Key="BrushSecundaria" Color="{StaticResource ColorSecundario}" />
    <SolidColorBrush x:Key="BrushFondo" Color="{StaticResource ColorFondo}" />
    <SolidColorBrush x:Key="BrushTexto" Color="{StaticResource ColorTexto}" />
    <SolidColorBrush x:Key="BrushBlanco" Color="White" />

    <!-- Estilo de botón -->
    <Style x:Key="EstiloBoton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushPrimaria}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSecundaria}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrushSecundaria}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Estilo para TextBox -->
    <Style x:Key="EstiloTextBox" TargetType="TextBox">
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaria}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <!--Setter Property="CornerRadius" Value="4"/-->
    </Style>

    <!-- Estilo de títulos -->
    <Style x:Key="EstiloTitulo" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushPrimaria}"/>
        <Setter Property="Margin" Value="0,10,0,20"/>
    </Style>

    <!-- Estilo para ListView -->
    <Style x:Key="EstiloLista" TargetType="ListView">
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaria}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="5"/>
    </Style>

</ResourceDictionary>
