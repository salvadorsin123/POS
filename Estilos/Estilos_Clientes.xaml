<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fondo principal de la vista -->
    <SolidColorBrush x:Key="FondoClientes" Color="#FFF6F6F6"/>

    <!-- Color de acento -->
    <SolidColorBrush x:Key="ColorPrimario" Color="#FF007ACC"/>
    <SolidColorBrush x:Key="ColorTextoClaro" Color="White"/>
    <SolidColorBrush x:Key="ColorTextoOscuro" Color="#333"/>

    <!-- Estilo para los títulos -->
    <Style x:Key="EstiloTituloClientes" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource ColorPrimario}"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <!-- Estilo para etiquetas -->
    <Style x:Key="EstiloEtiquetaClientes" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextoOscuro}"/>
        <Setter Property="Margin" Value="0,5,0,2"/>
    </Style>

    <!-- Estilo para TextBox -->
    <Style x:Key="EstiloInputClientes" TargetType="TextBox">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="BorderBrush" Value="#CCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Width" Value="250"/>
    </Style>

    <!-- Estilo para botones -->
    <Style x:Key="EstiloBotonClientes" TargetType="Button">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Background" Value="{StaticResource ColorPrimario}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextoClaro}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="100"/>
    </Style>

    <!-- Estilo para el contenedor principal -->
    <Style x:Key="EstiloContenedorClientes" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FondoClientes}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="#DDD"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>