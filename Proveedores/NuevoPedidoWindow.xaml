<Window x:Class="POS.Proveedores.NuevoPedidoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POS.Proveedores"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Nuevo Pedido" Height="auto" Width="auto"
        WindowState="Maximized"
        >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <!-- Sección de proveedor -->
        <Label Content="Proveedor:" Grid.Row="0"/>
        <ComboBox x:Name="cbProveedores" Grid.Row="1" DisplayMemberPath="cNombreP" 
                  Margin="0,0,0,10" SelectionChanged="CbProveedores_SelectionChanged"/>

        <!-- Sección de productos disponibles -->
        <Label Content="Productos disponibles:" Grid.Row="2"/>
        <DataGrid x:Name="dgProductosDisponibles" Grid.Row="3" AutoGenerateColumns="False" 
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Producto" Binding="{Binding cProducto}"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding nPrecioUnitario, StringFormat=C}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Controles para agregar productos -->
        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right">
            <Label Content="Cantidad:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtCantidad" Width="50" Margin="10,0,0,0"/>
            <Button Content="Agregar" Margin="10,0,5,0" Click="BtnAgregar_Click"/>
            <Button Content="Limpiar Todo" Margin="5,0,0,0" Click="BtnLimpiar_Click"/>
        </StackPanel>

        <!-- Productos en pedido -->
        <Label Content="Productos en pedido:" Grid.Row="5"/>
        <DataGrid x:Name="dgProductosPedido" Grid.Row="6" AutoGenerateColumns="False" 
                  Margin="0,0,0,10" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Producto" Binding="{Binding cProducto}"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding nCantidad}"/>
                <DataGridTextColumn Header="Precio Unitario" Binding="{Binding nPrecioUnitario, StringFormat=C}"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding nSubtotal, StringFormat=C}"/>
                <DataGridTemplateColumn Header="Acción">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Eliminar" Click="BtnEliminarProducto_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Sección de anticipo -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,10">
            <Label Content="Anticipo:" VerticalAlignment="Center" Width="80"/>
            <TextBox x:Name="txtAnticipo" Width="100" Margin="5,0" Text="{Binding Anticipo, StringFormat=C}"/>
            <Button Content="Abonar" Margin="10,0,0,0" Width="80" Click="BtnAbonar_Click"/>
        </StackPanel>

        <!-- Resumen de pagos -->
        <StackPanel Grid.Row="8" Orientation="Vertical" Margin="0,10">
            <TextBlock Text="Resumen de Pagos:" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Pedido:" Width="100"/>
                <TextBlock x:Name="txtTotalPedido" Text="{Binding TotalPedido, StringFormat=C}" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Anticipo:" Width="100"/>
                <TextBlock x:Name="txtAnticipoTotal" Text="{Binding AnticipoTotal, StringFormat=C}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Saldo Pendiente:" Width="100"/>
                <TextBlock x:Name="txtSaldoPendiente" Text="{Binding SaldoPendiente, StringFormat=C}" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <!-- Observaciones -->
        <Label Content="Observaciones:" Grid.Row="9"/>
        <TextBox x:Name="txtObservaciones" Grid.Row="10" Margin="0,0,0,10" AcceptsReturn="True"/>

        <!-- Botones finales -->
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Aceptar" Width="100" Margin="0,0,10,0" Click="BtnAceptar_Click"/>
            <Button Content="Cancelar" Width="100" Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>